{
    "workbench.externalBrowser": "brave-browser",
    "quarto.render.previewType": "external",
    "workbench.externalUriOpeners": {
        "http": "default",
        "https": "default"
    },
    "simpleBrowser.showOnSave": false,
    "window.restoreWindows": "all",
    "window.newWindowDimensions": "inherit",
    "quarto.path": "~/opt/quarto-1.8.27/bin/quarto",
    "quarto.useBundledQuartoInPositron": false,
    "quarto.render.renderOnSaveShiny": false,
    "quarto.usePipQuarto": false,
    "typescript.implementationsCodeLens.enabled": true,
    "chat.context.storage": "workspace-local",
    "chat.history.path": "./.antigravity/conversations",
    "agent.knowledge.path": "./.antigravity/knowledge",
    "agent.logs.path": "./.antigravity/logs",
    "tasks.storage.path": "./.antigravity/tasks",
    "agent.knowledge.indexType": "cloud-agent",
    "agent.default.settings": {
        "mode": "fast",
        "model": "gemini-3.0-flash",
        "indexingModel": "gemini-3.0-flash"
    },
    "agent.model.forceLocalOverride": true,
    "embedding.engine.local.path": "./.antigravity/embeddings",
    "embedding.provider": "ollama",
    "embedding.model": "nomic-embed-text"
}