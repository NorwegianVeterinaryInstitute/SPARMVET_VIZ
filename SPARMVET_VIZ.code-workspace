{
  "folders": [
    {
      "name": "🚀 FULL PROJECT",
      "path": "."
    },
    {
      "name": "AGENTS",
      "path": ".agents"
    },
    {
      "name": "ANTIGRAVITY",
      "path": ".antigravity"
    },
    {
      "name": "🍊 EVE",
      "path": "EVE_WORK"
    },
    {
      "name": "🧪 tmp",
      "path": "tmp"
    },
    {
      "name": " ⚙️ LIBS",
      "path": "libs"
    },
    {
      "name": "🎨 ASSETS",
      "path": "assets"
    },
    {
      "name": "CONFIG",
      "path": "config"
    },
    {
      "name": "📚 QUARTO DOCS",
      "path": "docs"
    },
    {
      "name": "📺 RENDERED DOCUMENTATION",
      "path": "_book"
    }
  ],
  "settings": {
    "path-intellisense.mappings": {
      // This maps the '/' character to your Quarto Docs root
      "/": "${workspaceFolder:📚 QUARTO DOCS}",
      // These force the extension to look inside the subfolders of your docs
      "architecture": "${workspaceFolder:📚 QUARTO DOCS}/architecture",
      "modules": "${workspaceFolder:📚 QUARTO DOCS}/modules",
      "guide": "${workspaceFolder:📚 QUARTO DOCS}/guide",
      "appendix": "${workspaceFolder:📚 QUARTO DOCS}/appendix"
    },
    // Crucial: Tells the extension NOT to use the project root (🚀 FULL PROJECT)
    "path-intellisense.absolutePathToWorkspace": false,
    // Crucial: Ensures suggestions appear as you type in YAML
    "path-intellisense.extensionOnImport": true,
    // Silence the defaults so they don't conflict
    "typescript.suggest.paths": false,
    "javascript.suggest.paths": false,
    // Force VS Code to treat the YAML as a navigation-friendly file
    "files.associations": {
      "_quarto.yml": "yaml"
    },
    "bookmarks.saveBookmarksInProject": true,
    "bookmarks.sideBar.hideWelcome": true,
    "bookmarks.sideBar.expanded": true,
    "workbench.colorCustomizations": {
      "activityBar.activeBackground": "#1f6fd0",
      "activityBar.background": "#1f6fd0",
      "activityBar.foreground": "#e7e7e7",
      "activityBar.inactiveForeground": "#e7e7e799",
      "activityBarBadge.background": "#ee90bb",
      "activityBarBadge.foreground": "#15202b",
      "commandCenter.border": "#e7e7e799",
      "sash.hoverBorder": "#1f6fd0",
      "statusBar.background": "#1857a4",
      "statusBar.foreground": "#e7e7e7",
      "statusBarItem.hoverBackground": "#1f6fd0",
      "statusBarItem.remoteBackground": "#1857a4",
      "statusBarItem.remoteForeground": "#e7e7e7",
      "titleBar.activeBackground": "#1857a4",
      "titleBar.activeForeground": "#e7e7e7",
      "titleBar.inactiveBackground": "#1857a499",
      "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#1857a4",
    "favorites.dataLocation": "${workspaceFolder}/.vscode/favorites",
    "workbench.editor.openSideBySideDirection": "right",
    "workbench.editor.closeEmptyGroups": false
  },
  "extensions": {
    "recommendations": [
      "wattenberger.footsteps",
      "alefragnani.bookmarks"
    ]
  }
}