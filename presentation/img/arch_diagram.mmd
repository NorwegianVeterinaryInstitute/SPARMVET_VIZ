%%{init: {'theme': 'neutral', 'themeVariables': {'fontSize': '14px'}}}%%
graph LR
    classDef input fill:#e1f5fe,stroke:#01579b;
    classDef logic fill:#fff3e0,stroke:#e65100;
    classDef output fill:#f1f8e9,stroke:#33691e;

    subgraph Ext["External World"]
        Galaxy["Galaxy / IRIDA"]:::input
        Upload["User Uploads (.tsv)"]:::input
    end

    subgraph Dash["Dashboard Core"]
        direction LR
        subgraph Ingress["Layer 1: Ingestion"]
            Connector["Connector"]:::logic
            Ingest["Ingestor"]:::logic
            IC["input_fields\ncontract"]:::output
            Galaxy --> Connector --> Ingest --> IC
            Upload --> Ingest
        end
        subgraph Transform["Layer 2: Wrangling"]
            Wrangler["Wrangler"]:::logic
            OC["output_fields\ncontract"]:::output
            IC --> Wrangler --> OC
        end
        subgraph Assembly["Layer 3: Assembly"]
            Assembler["Assembler"]:::logic
            MT["Master Tidy Table"]:::output
            OC --> Assembler --> MT
        end
        subgraph Viz["Layer 4: Visualisation"]
            Ctrl{{"Orchestrator"}}:::logic
            Factory["VizFactory"]:::logic
            UI["Shiny UI"]:::output
            MT --> Ctrl -->|"Filtered"| Factory --> UI
            UI -->|"User filter"| Ctrl
        end
    end
    Config["YAML Manifests"]:::input
    Config -.->|"ADR-013"| IC
    Config -.->|"Actions"| Wrangler
    Config -.->|"Contract"| OC
    Config -.->|"Plot specs"| Factory
